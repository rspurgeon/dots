#!/usr/bin/env bash

set -euo pipefail

GPAKOSZ_REPO_DIR="$HOME/dev/gpakosz"
GPAKOSZ_CONF="$GPAKOSZ_REPO_DIR/.tmux.conf"
TMUX_CONF_LINK="$HOME/.tmux.conf"
TPM_DIR="$HOME/.tmux/plugins/tpm"

mkdir -p "$HOME/dev"

if [ ! -d "$GPAKOSZ_REPO_DIR" ]; then
    git clone https://github.com/gpakosz/.tmux.git "$GPAKOSZ_REPO_DIR"
fi

ln -sfn "$GPAKOSZ_CONF" "$TMUX_CONF_LINK"

if [ ! -d "$TPM_DIR" ]; then
    git clone https://github.com/tmux-plugins/tpm "$TPM_DIR"
fi

if [ -n "${TMUX:-}" ]; then
    tmux source-file "$HOME/.tmux.conf"
    tmux source-file "$HOME/.tmux.conf.local"
    "$TPM_DIR/bin/install_plugins"
else
    session_name="dots-setup-tmux"
    tmux new-session -d -s "$session_name" 'sleep 5' 2>/dev/null || true
    tmux source-file "$HOME/.tmux.conf"
    tmux source-file "$HOME/.tmux.conf.local"
    "$TPM_DIR/bin/install_plugins"
    tmux kill-session -t "$session_name" 2>/dev/null || true

    echo "Base tmux config linked at $TMUX_CONF_LINK"
    echo "TPM installed at $TPM_DIR"
    echo "tmux plugins installed"
fi
