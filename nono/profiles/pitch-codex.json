{
  "extends": "codex",
  "meta": {
    "name": "pitch-codex",
    "description": "Conservative rspurgeon/pitch additions on top of the built-in codex profile"
  },
  "filesystem": {
    "allow": [
      "$TMPDIR",
      "$HOME/.cache/mise",
      "$HOME/.cache/go",
      "$HOME/.cache/golangci-lint",
      "$HOME/.cache/agent-status",
      "$HOME/.ssh/agent",
      "/home/rspurgeon/dev/rspurgeon/pitch/.git",
      "/home/rspurgeon/dev/rspurgeon/pitch/.git/worktrees"
    ],
    "read": [
      "/etc",
      "/proc",
      "/usr",
      "/usr/local/sbin",
      "/home/rspurgeon/dev/rspurgeon/dots/.config/git",
      "$HOME/.config/git",
      "$HOME/dev/rspurgeon/dots/.config/mise",
      "$HOME/.config/go",
      "$HOME/.config/gh",
      "$HOME/.config/mise",
      "$HOME/.ssh",
      "$HOME/.local/share/mise/installs",
      "$HOME/.local/share/mise/shims",
      "$HOME/.local/share/omarchy/bin",
      "$HOME/bin"
    ]
  }
}
