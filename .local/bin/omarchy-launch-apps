#!/usr/bin/env bash

set -euo pipefail

started_elephant=0

cleanup() {
  if (( started_elephant )); then
    pkill -x elephant >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

if ! pgrep -x elephant >/dev/null; then
  setsid uwsm-app -- elephant >/dev/null 2>&1 &
  started_elephant=1

  for _ in {1..40}; do
    pgrep -x elephant >/dev/null && break
    sleep 0.05
  done
fi

if ! pgrep -f "walker --gapplication-service" >/dev/null; then
  setsid uwsm-app -- env GSK_RENDERER=cairo walker --gapplication-service >/dev/null 2>&1 &
fi

walker --width 644 --maxheight 300 --minheight 300 "$@"
