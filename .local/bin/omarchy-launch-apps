#!/usr/bin/env bash

set -euo pipefail

export OMARCHY_PATH="${OMARCHY_PATH:-$HOME/.local/share/omarchy}"
case ":$PATH:" in
  *":$OMARCHY_PATH/bin:"*) ;;
  *) export PATH="$OMARCHY_PATH/bin:$PATH" ;;
esac

elephant_has_omarchy_path() {
  local env_path
  local pid
  pid="$(pgrep -xo elephant || true)"
  [ -n "$pid" ] || return 1

  env_path="$(tr '\0' '\n' <"/proc/$pid/environ" 2>/dev/null | sed -n 's/^PATH=//p')"
  case ":$env_path:" in
    *":$OMARCHY_PATH/bin:"*) return 0 ;;
    *) return 1 ;;
  esac
}

start_elephant() {
  if systemctl --user list-unit-files elephant.service >/dev/null 2>&1; then
    systemctl --user start elephant.service >/dev/null 2>&1 && return 0
  fi

  setsid uwsm-app -- env OMARCHY_PATH="$OMARCHY_PATH" PATH="$PATH" elephant >/dev/null 2>&1 &
}

if pgrep -x elephant >/dev/null && ! elephant_has_omarchy_path; then
  if systemctl --user list-unit-files elephant.service >/dev/null 2>&1; then
    systemctl --user restart elephant.service >/dev/null 2>&1 || true
  fi
fi

if ! pgrep -x elephant >/dev/null; then
  start_elephant
fi

for _ in {1..80}; do
  [ -S "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/elephant/elephant.sock" ] && break
  sleep 0.05
done

if ! pgrep -f "walker --gapplication-service" >/dev/null; then
  setsid uwsm-app -- env OMARCHY_PATH="$OMARCHY_PATH" PATH="$PATH" GSK_RENDERER=cairo walker --gapplication-service >/dev/null 2>&1 &
fi

for _ in {1..80}; do
  [ -S "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/walker/walker.sock" ] && break
  sleep 0.05
done

walker --width 644 --maxheight 300 --minheight 300 "$@"
