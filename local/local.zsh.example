# Untracked shell overrides for this machine.
# Copy relevant lines into ~/.config/rspurgeon/local.zsh.

# Example machine-local paths or secrets loaded from files
# export OPENCODE_SERVER_PASSWORD="$(cat ~/.tok/opencode_server_password)"
# export KONGCTL_E2E_KONNECT_PAT="$(cat ~/.tok/kongctl-acceptance)"

# Stable symlink pattern for expiring tokens used by mise:
#   ~/.tok/GITHUB_TOKEN -> ~/.tok/YYYYMMDD-GH_TOKEN
#
# mise/config.toml can read this through settings.github.credential_command.
# MISE_GITHUB_TOKEN is scoped to mise, unlike broad GITHUB_TOKEN.
# if [ -s "$HOME/.tok/GITHUB_TOKEN" ]; then
#     export MISE_GITHUB_TOKEN="$(cat "$HOME/.tok/GITHUB_TOKEN")"
# fi
#
# Do not export GITHUB_TOKEN globally; it can shadow git, gh, and other auth.
# unset GITHUB_TOKEN
